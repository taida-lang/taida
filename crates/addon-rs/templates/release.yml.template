# .github/workflows/release.yml — Taida addon release workflow
#
# Generated by `taida init --target rust-addon` from the standard
# addon release template (C14-3).
#
# ── Symmetry with the Taida core release workflow ─────────────────
#
# This template is structurally symmetric with
# `shijimic/taida/.github/workflows/release.yml`:
#
#   * Jobs: prepare -> gate -> build -> publish (identical 4-stage
#     contract). Each stage has the same name and responsibility as
#     the core counterpart.
#   * Tag regex: Taida version scheme `^[a-z]\.[0-9]+(\.[a-z0-9][a-z0-9-]*)?$`
#     (without the `@` prefix — addons use bare tags, the core uses
#     `@`-prefixed tags).
#   * Release author: `github-actions[bot]` (via `github.token`). The
#     release is created exclusively by this workflow, never by a
#     user CLI session (see C14_DESIGN.md §非交渉条件 5).
#   * Build matrix: 5 targets (linux x86_64/aarch64, macos
#     x86_64/aarch64, windows x86_64). aarch64-linux uses `cross`.
#
# ── Tag trigger ───────────────────────────────────────────────────
#
# Tags matching the Taida version scheme fire this workflow:
#
#     ^[a-z]\.[0-9]+(\.[a-z0-9][a-z0-9-]*)?$
#
# Examples: `a.1`, `a.12`, `b.1.rc`, `b.3.rc2`, `aa.7.beta`.
# Semver-style tags (`v1.2.3`, `0.1.0`) are intentionally ignored.
#
# ── What `taida publish` does NOT do ──────────────────────────────
#
# Under C14 the `taida publish` CLI only pushes the tag. It does NOT
# build cdylibs, compute SHA-256, write `addon.lock.toml`, or call
# `gh release create`. All of those responsibilities live here.

name: Release

on:
  push:
    tags:
      # Taida version tags: one-letter or two-letter generation.
      - "[a-z].[0-9]*"
      - "[a-z][a-z].[0-9]*"
  workflow_dispatch:
    inputs:
      tag:
        description: "Release tag to package, for example a.1.rc"
        required: true
        type: string

permissions:
  contents: write

env:
  CARGO_TERM_COLOR: always
  LIBRARY_STEM: {{LIBRARY_STEM}}
  CRATE_DIR: {{CRATE_DIR}}

jobs:
  prepare:
    name: Prepare Release Metadata
    runs-on: ubuntu-latest
    outputs:
      release_ref: ${{ steps.resolve.outputs.release_ref }}
      release_tag: ${{ steps.resolve.outputs.release_tag }}
    steps:
      - name: Resolve and validate release tag
        id: resolve
        shell: bash
        env:
          EVENT_NAME: ${{ github.event_name }}
          EVENT_REF: ${{ github.ref }}
          EVENT_REF_NAME: ${{ github.ref_name }}
          INPUT_TAG: ${{ github.event.inputs.tag }}
        run: |
          set -euo pipefail
          if [[ "${EVENT_NAME}" == "workflow_dispatch" ]]; then
            release_tag="${INPUT_TAG}"
            release_ref="refs/tags/${release_tag}"
          else
            release_tag="${EVENT_REF_NAME}"
            release_ref="${EVENT_REF}"
          fi

          # Taida version scheme (addon side, no @ prefix).
          if [[ ! "${release_tag}" =~ ^[a-z]\.[0-9]+(\.[a-z0-9][a-z0-9-]*)?$ ]] \
             && [[ ! "${release_tag}" =~ ^[a-z][a-z]\.[0-9]+(\.[a-z0-9][a-z0-9-]*)?$ ]]; then
            echo "invalid release tag: ${release_tag}" >&2
            echo "must match ^[a-z]{1,2}\\.[0-9]+(\\.[a-z0-9][a-z0-9-]*)?\$" >&2
            exit 1
          fi

          printf 'release_ref=%s\n' "${release_ref}" >> "${GITHUB_OUTPUT}"
          printf 'release_tag=%s\n' "${release_tag}" >> "${GITHUB_OUTPUT}"

  gate:
    name: Release Gate
    needs: prepare
    runs-on: ubuntu-latest
    env:
      TAIDA_RELEASE_TAG: ${{ needs.prepare.outputs.release_tag }}
    steps:
      - uses: actions/checkout@v5
        with:
          ref: ${{ needs.prepare.outputs.release_ref }}
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: clippy, rustfmt
      - uses: actions/cache@v5
        with:
          path: |
            ~/.cargo/registry/index/
            ~/.cargo/registry/cache/
            ~/.cargo/git/db/
            ~/.cargo/git/checkouts/
            target/
          key: ${{ runner.os }}-cargo-${{ github.job }}-${{ hashFiles('**/Cargo.lock') }}
          restore-keys: |
            ${{ runner.os }}-cargo-${{ github.job }}-
            ${{ runner.os }}-cargo-
      - name: cargo fmt --check
        working-directory: ${{ env.CRATE_DIR }}
        run: cargo fmt --all -- --check
      - name: cargo clippy
        working-directory: ${{ env.CRATE_DIR }}
        run: cargo clippy --all-targets -- -D warnings
      - name: cargo test
        working-directory: ${{ env.CRATE_DIR }}
        run: cargo test --all-targets

  build:
    name: Build ${{ matrix.triple }}
    needs:
      - prepare
      - gate
    runs-on: ${{ matrix.runner }}
    env:
      TAIDA_RELEASE_TAG: ${{ needs.prepare.outputs.release_tag }}
    strategy:
      fail-fast: false
      matrix:
        include:
          - triple: x86_64-unknown-linux-gnu
            runner: ubuntu-latest
            ext: so
            prefix: lib
          - triple: aarch64-unknown-linux-gnu
            runner: ubuntu-latest
            ext: so
            prefix: lib
            cross: true
          - triple: x86_64-apple-darwin
            runner: macos-15-intel
            ext: dylib
            prefix: lib
          - triple: aarch64-apple-darwin
            runner: macos-14
            ext: dylib
            prefix: lib
          - triple: x86_64-pc-windows-msvc
            runner: windows-latest
            ext: dll
            prefix: ""
    steps:
      - uses: actions/checkout@v5
        with:
          ref: ${{ needs.prepare.outputs.release_ref }}

      - uses: dtolnay/rust-toolchain@stable
        with:
          targets: ${{ matrix.triple }}

      - uses: actions/cache@v5
        with:
          path: |
            ~/.cargo/registry/index/
            ~/.cargo/registry/cache/
            ~/.cargo/git/db/
            ~/.cargo/git/checkouts/
            target/
          key: ${{ runner.os }}-cargo-build-${{ matrix.triple }}-${{ hashFiles('**/Cargo.lock') }}
          restore-keys: |
            ${{ runner.os }}-cargo-build-${{ matrix.triple }}-
            ${{ runner.os }}-cargo-build-

      - name: Install cross (non-native targets)
        if: matrix.cross
        run: cargo install cross --locked

      - name: Build cdylib (native)
        if: "!matrix.cross"
        working-directory: ${{ env.CRATE_DIR }}
        shell: bash
        run: cargo build --locked --release --target ${{ matrix.triple }}

      - name: Build cdylib (cross)
        if: matrix.cross
        working-directory: ${{ env.CRATE_DIR }}
        shell: bash
        run: cross build --locked --release --target ${{ matrix.triple }}

      - name: Pack artefact and compute SHA-256
        id: pack
        shell: bash
        working-directory: ${{ env.CRATE_DIR }}
        run: |
          set -euo pipefail
          src="target/${{ matrix.triple }}/release/${{ matrix.prefix }}${LIBRARY_STEM}.${{ matrix.ext }}"
          if [ ! -f "$src" ]; then
            echo "expected artifact $src not found" >&2
            ls -l "target/${{ matrix.triple }}/release/" || true
            exit 1
          fi
          dst="${{ matrix.prefix }}${LIBRARY_STEM}-${{ matrix.triple }}.${{ matrix.ext }}"
          cp "$src" "$dst"
          if command -v sha256sum >/dev/null; then
            sha=$(sha256sum "$dst" | awk '{print $1}')
          else
            sha=$(shasum -a 256 "$dst" | awk '{print $1}')
          fi
          printf '"%s" = "sha256:%s"\n' "${{ matrix.triple }}" "$sha" \
            > "${{ matrix.triple }}.toml.fragment"
          printf 'artifact=%s\n' "$dst" >> "$GITHUB_OUTPUT"
          printf 'fragment=%s\n' "${{ matrix.triple }}.toml.fragment" >> "$GITHUB_OUTPUT"
          printf 'sha256=%s\n' "$sha" >> "$GITHUB_OUTPUT"

      - uses: actions/upload-artifact@v4
        with:
          name: prebuild-${{ matrix.triple }}
          path: |
            ${{ env.CRATE_DIR }}/${{ steps.pack.outputs.artifact }}
            ${{ env.CRATE_DIR }}/${{ steps.pack.outputs.fragment }}
          if-no-files-found: error

  publish:
    name: Publish Release
    needs:
      - prepare
      - build
    runs-on: ubuntu-latest
    permissions:
      contents: write
    env:
      RELEASE_TAG: ${{ needs.prepare.outputs.release_tag }}
    steps:
      - uses: actions/checkout@v5
        with:
          ref: ${{ needs.prepare.outputs.release_ref }}

      - uses: actions/download-artifact@v4
        with:
          path: prebuild-artifacts

      - name: Assemble addon.lock.toml
        shell: bash
        run: |
          set -euo pipefail
          mkdir -p native
          {
            printf '# native/addon.lock.toml\n'
            printf '# Generated by CI. Do NOT edit manually.\n'
            printf '# Release tag: %s\n\n' "${RELEASE_TAG}"
            printf '[targets]\n'
          } > native/addon.lock.toml

          # Canonical order matches the build matrix above.
          for target in \
            x86_64-unknown-linux-gnu \
            aarch64-unknown-linux-gnu \
            x86_64-apple-darwin \
            aarch64-apple-darwin \
            x86_64-pc-windows-msvc; do
            frag="prebuild-artifacts/prebuild-${target}/${target}.toml.fragment"
            if [ -f "$frag" ]; then
              cat "$frag" >> native/addon.lock.toml
            else
              echo "missing fragment for ${target}" >&2
              exit 1
            fi
          done
          cat native/addon.lock.toml

      - name: Assemble prebuild-targets.toml.txt
        shell: bash
        run: |
          set -euo pipefail
          {
            printf '# Drop-in fragment for native/addon.toml.\n'
            printf '# Replace the existing [library.prebuild.targets] block.\n\n'
            printf '[library.prebuild.targets]\n'
          } > prebuild-targets.toml.txt

          for target in \
            x86_64-unknown-linux-gnu \
            aarch64-unknown-linux-gnu \
            x86_64-apple-darwin \
            aarch64-apple-darwin \
            x86_64-pc-windows-msvc; do
            frag="prebuild-artifacts/prebuild-${target}/${target}.toml.fragment"
            cat "$frag" >> prebuild-targets.toml.txt
          done
          cat prebuild-targets.toml.txt

      - name: Collect release assets
        shell: bash
        run: |
          set -euo pipefail
          mkdir -p dist
          find prebuild-artifacts -type f \
            \( -name "lib*.so" -o -name "lib*.dylib" -o -name "*.dll" \) \
            -exec cp {} dist/ \;
          cp native/addon.lock.toml dist/addon.lock.toml
          cp prebuild-targets.toml.txt dist/prebuild-targets.toml.txt
          ls -l dist/

      - name: Generate SHA256SUMS
        working-directory: dist
        shell: bash
        run: |
          set -euo pipefail
          if command -v sha256sum >/dev/null; then
            sha256sum * > SHA256SUMS
          else
            shasum -a 256 * > SHA256SUMS
          fi
          cat SHA256SUMS

      - name: Publish GitHub release
        env:
          GH_TOKEN: ${{ github.token }}
          REPO: ${{ github.repository }}
        shell: bash
        run: |
          set -euo pipefail
          HEADER="Taida addon release for \`${RELEASE_TAG}\`.

          Assets:
          - host cdylibs for 5 targets
          - \`addon.lock.toml\` (SHA-256 aggregated from the build matrix)
          - \`prebuild-targets.toml.txt\` (drop-in fragment for \`native/addon.toml\`)
          - \`SHA256SUMS\`

          Release author: \`github-actions[bot]\`.

          ---
          "
          if ! GENERATED=$(gh api "repos/${REPO}/releases/generate-notes" \
            -f tag_name="${RELEASE_TAG}" -q '.body' 2>/dev/null); then
            GENERATED=""
          fi
          gh release create "${RELEASE_TAG}" dist/* \
            --repo "${REPO}" \
            --title "${RELEASE_TAG}" \
            --notes "${HEADER}${GENERATED}"
